# Base de datos Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth v5 - generar con: npx auth secret
AUTH_SECRET="your-random-secret-here"

# Opcional: URL de la app (necesario en producción)
# NEXTAUTH_URL="https://tu-dominio.com"

# Google Gemini AI - obtener en https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# DeepSeek AI (fallback si Gemini falla) - obtener en https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="your-deepseek-api-key-here"

# Opcional: variables para el seed del usuario inicial
# SEED_EMAIL="pablo@entrenamientos.local"
# SEED_PASSWORD="changeme123"
# SEED_NAME="Pablo"
