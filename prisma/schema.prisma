// prisma/schema.prisma
// SDD Fase 1 — Modelo de datos para entrenamientos ciclistas

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Sport {
  MTB
  SPINNING
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // bcrypt hash
  createdAt DateTime @default(now())

  sessions                   TrainingSession[]
  deletedSessionFingerprints DeletedSessionFingerprint[]
  scheduledTrainings         ScheduledTraining[]
}

model TrainingSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   // Default: "Martes 22 de agosto por la mañana"
  date      DateTime
  duration  Int      // en segundos
  sport     Sport
  hrAvg     Int?
  hrMax     Int?
  hrMin     Int?
  trimp     Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hrSamples    HRSample[]
  laps         Lap[]
  cardiacDrift       CardiacDrift?
  aiAnalyses         AIAnalysis[]
  scheduledTraining  ScheduledTraining?

  @@unique([userId, date])
  @@index([date])
}

model DeletedSessionFingerprint {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String   // hash(date + duration)
  deletedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
}

model HRSample {
  id                String @id @default(cuid())
  sessionId         String
  timeOffsetSeconds Int    // segundos desde inicio de sesión
  hr                Int

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Lap {
  id                 String @id @default(cuid())
  sessionId          String
  lapNumber          Int
  startOffsetSeconds Int    // segundo de inicio desde comienzo de sesión
  durationSeconds    Int    // duración del lap en segundos

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model CardiacDrift {
  id                         String @id @default(cuid())
  sessionId                  String @unique
  hrStart                    Int    // HR promedio primera mitad
  hrEnd                      Int    // HR promedio segunda mitad
  driftPercent               Float
  steadyStateDurationSeconds Int
  analysis                   String?

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AIAnalysis {
  id              String   @id @default(cuid())
  sessionId       String
  summary         String
  recommendations String?
  createdAt       DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ScheduledTraining {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  sport           Sport
  durationPlanned Int?     // en minutos
  notes           String?
  completed       Boolean  @default(false)
  linkedSessionId String?  @unique
  createdAt       DateTime @default(now())

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedSession TrainingSession? @relation(fields: [linkedSessionId], references: [id], onDelete: SetNull)
}
